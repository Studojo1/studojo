# Database (local: localhost; Docker overrides via docker-compose)
DATABASE_URL=postgresql://studojo:studojo@localhost:5432/postgres

# OpenAI (for resume PDF parsing)
OPENAI_API_KEY=your_openai_api_key_here

# Better Auth
BETTER_AUTH_SECRET=your-secret
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio Verify API (phone OTP). Required for sending and verifying codes.
# Uses Twilio Verify API which handles OTP generation, delivery, and verification.
# sendOTP is fire-and-forget (not awaited) per better-auth recommendation.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# Optional: comma-separated user IDs for admin access
# ADMIN_USER_IDS=id1,id2

# Control plane (Assignment Dojo jobs)
VITE_CONTROL_PLANE_URL=http://localhost:8080
